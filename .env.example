# KWIN City Portal - Environment Variables

# Next.js
NEXT_PUBLIC_APP_NAME="KWIN City Portal"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Mapbox (Optional - for future spatial visualization)
# NEXT_PUBLIC_MAPBOX_TOKEN=your_token_here

# Analytics (Optional)
# NEXT_PUBLIC_GA_ID=your_ga_id_here
NEXT_PUBLIC_CLARITY_PROJECT_ID=w90fdbtt4x

# Contact inbox
CONTACT_EMAIL="hello@kwin-city.com"

# Discovery signals (optional)
# INDEXNOW_KEY=your_indexnow_key
# INDEXNOW_HOST=kwin-city.com

# API (Optional - for future backend integration)
# NEXT_PUBLIC_API_URL=http://localhost:3001
